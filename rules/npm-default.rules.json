{
  "id": "npm-default",
  "version": "1.0.0",
  "description": "Default npm supply-chain security detection rules.",
  "rules": [
    {
      "id": "npm.ignore-scripts-bypass",
      "scope": "script",
      "title": "ignore-scripts bypass attempt",
      "description": "Script tries to modify npm script-shell or bypass expected install controls.",
      "pattern": "\\bnpm\\s+config\\s+set\\s+script-shell\\b",
      "flags": "i",
      "severity": "high",
      "confidence": "medium",
      "weight": 4,
      "tags": ["npm", "policy-bypass"],
      "references": ["https://cheatsheetseries.owasp.org/cheatsheets/NPM_Security_Cheat_Sheet.html"]
    },
    {
      "id": "npm.remote-stream-node",
      "scope": "script",
      "title": "Remote stream to node",
      "description": "Remote content piped directly into node.",
      "pattern": "\\b(?:curl|wget|iwr|invoke-webrequest)\\b.*\\|\\s*node(?:\\.exe)?\\b",
      "flags": "i",
      "severity": "critical",
      "confidence": "high",
      "weight": 8,
      "tags": ["rce", "supply-chain"],
      "references": ["https://www.splunk.com/en_us/blog/security/npm-supply-chain-attack-detection-analysis.html"]
    },
    {
      "id": "npm.remote-stream-shell",
      "scope": "script",
      "title": "Remote stream to shell",
      "description": "Remote content piped directly into shell/interpreter.",
      "pattern": "\\b(?:curl|wget|iwr|invoke-webrequest)\\b.*\\|\\s*(?:bash|sh|zsh|pwsh|powershell(?:\\.exe)?|cmd(?:\\.exe)?|iex|invoke-expression)\\b",
      "flags": "i",
      "severity": "critical",
      "confidence": "high",
      "weight": 8,
      "tags": ["rce", "supply-chain"],
      "references": ["https://www.splunk.com/en_us/blog/security/npm-supply-chain-attack-detection-analysis.html"]
    },
    {
      "id": "npm.node-external-url",
      "scope": "script",
      "title": "Node executes remote URL",
      "description": "Script calls node with a remote JavaScript URL.",
      "pattern": "\\bnode(?:\\.exe)?\\s+https?://[^\\s]+\\.js\\b",
      "flags": "i",
      "severity": "high",
      "confidence": "high",
      "weight": 6,
      "tags": ["rce", "remote-code"],
      "references": ["https://docs.npmjs.com/cli/v11/using-npm/scripts/"]
    },
    {
      "id": "npm.encoded-powershell",
      "scope": "script",
      "title": "Encoded PowerShell",
      "description": "Script uses encoded PowerShell payload.",
      "pattern": "\\bpowershell(?:\\.exe)?\\b.*(?:-enc|-encodedcommand)\\b",
      "flags": "i",
      "severity": "high",
      "confidence": "high",
      "weight": 6,
      "tags": ["obfuscation", "powershell"],
      "references": []
    },
    {
      "id": "npm.invoke-expression",
      "scope": "script",
      "title": "Invoke-Expression usage",
      "description": "Script uses iex/Invoke-Expression.",
      "pattern": "\\b(?:iex|Invoke-Expression)\\b",
      "flags": "i",
      "severity": "high",
      "confidence": "high",
      "weight": 5,
      "tags": ["powershell", "rce"],
      "references": []
    },
    {
      "id": "npm.c2-endpoint",
      "scope": "script",
      "title": "Suspicious C2/exfil endpoint",
      "description": "Script references known exfiltration endpoint patterns.",
      "pattern": "discord(?:app)?\\.com/api/webhooks|api\\.telegram\\.org|hooks\\.slack\\.com/services|webhook\\.site|requestbin|smee\\.io|ngrok",
      "flags": "i",
      "severity": "high",
      "confidence": "medium",
      "weight": 5,
      "tags": ["exfiltration", "c2"],
      "references": ["https://www.splunk.com/en_us/blog/security/npm-supply-chain-attack-detection-analysis.html"]
    },
    {
      "id": "npm.cloud-metadata",
      "scope": "script",
      "title": "Cloud metadata endpoint access",
      "description": "Script targets cloud metadata endpoints.",
      "pattern": "169\\.254\\.169\\.254|metadata\\.google\\.internal|100\\.100\\.100\\.200|latest/meta-data|instance-data",
      "flags": "i",
      "severity": "high",
      "confidence": "high",
      "weight": 6,
      "tags": ["credential-theft", "metadata"],
      "references": []
    },
    {
      "id": "npm.sensitive-file-target",
      "scope": "script",
      "title": "Sensitive target file reference",
      "description": "Script references high-value credential/persistence files.",
      "pattern": "\\.npmrc|\\.ssh|authorized_keys|id_rsa|id_dsa|known_hosts|\\.bashrc|\\.zshrc|profile\\.ps1|startup",
      "flags": "i",
      "severity": "medium",
      "confidence": "medium",
      "weight": 3,
      "tags": ["persistence", "credential-access"],
      "references": []
    },
    {
      "id": "npm.eval",
      "scope": "script",
      "title": "eval usage",
      "description": "Script includes eval.",
      "pattern": "\\beval\\b",
      "flags": "i",
      "severity": "medium",
      "confidence": "medium",
      "weight": 3,
      "tags": ["obfuscation"],
      "references": []
    },
    {
      "id": "npm.network-download",
      "scope": "script",
      "title": "Network download command",
      "description": "Script uses network download utility.",
      "pattern": "\\b(?:curl|wget|invoke-webrequest|iwr)\\b",
      "flags": "i",
      "severity": "medium",
      "confidence": "high",
      "weight": 3,
      "tags": ["download"],
      "references": []
    },
    {
      "id": "npm.inline-exec",
      "scope": "script",
      "title": "Inline command execution",
      "description": "Inline command execution in lifecycle script.",
      "pattern": "\\b(?:node\\s+-e|bash\\s+-c|sh\\s+-c)\\b",
      "flags": "i",
      "severity": "medium",
      "confidence": "high",
      "weight": 3,
      "tags": ["rce"],
      "references": []
    },
    {
      "id": "npm.file.child-process-network",
      "scope": "file",
      "title": "Child process with network command",
      "description": "Referenced JS contains child-process + network/command behavior.",
      "pattern": "(?:child_process|execSync|execFileSync|spawnSync|spawn|exec)\\b[\\s\\S]{0,500}(?:https?://|curl|wget|invoke-webrequest|iwr|\\|\\s*(?:bash|sh|pwsh|powershell|cmd)|\\biex\\b|invoke-expression)",
      "flags": "i",
      "severity": "critical",
      "confidence": "high",
      "weight": 8,
      "tags": ["rce", "stager"],
      "references": ["https://www.splunk.com/en_us/blog/security/npm-supply-chain-attack-detection-analysis.html"]
    },
    {
      "id": "npm.file.c2-endpoint",
      "scope": "file",
      "title": "JS exfil endpoint usage",
      "description": "Referenced JS includes suspicious outbound endpoint patterns.",
      "pattern": "(?:fetch\\(|axios|https?\\.(?:request|get|post)|XMLHttpRequest|WebSocket)[\\s\\S]{0,500}(?:discord(?:app)?\\.com/api/webhooks|api\\.telegram\\.org|hooks\\.slack\\.com/services|webhook\\.site|requestbin|smee\\.io|ngrok|169\\.254\\.169\\.254|metadata\\.google\\.internal|100\\.100\\.100\\.200)",
      "flags": "i",
      "severity": "high",
      "confidence": "medium",
      "weight": 6,
      "tags": ["exfiltration", "c2"],
      "references": []
    },
    {
      "id": "npm.file.sensitive-write",
      "scope": "file",
      "title": "Sensitive file write",
      "description": "Referenced JS writes to sensitive credential/persistence targets.",
      "pattern": "fs\\.(?:writeFile|writeFileSync|appendFile|appendFileSync)\\s*\\([^\\)]*(?:\\.npmrc|\\.ssh|authorized_keys|id_rsa|id_dsa|known_hosts|\\.bashrc|\\.zshrc|profile|startup)",
      "flags": "i",
      "severity": "high",
      "confidence": "high",
      "weight": 7,
      "tags": ["persistence", "credential-access"],
      "references": []
    }
  ]
}
